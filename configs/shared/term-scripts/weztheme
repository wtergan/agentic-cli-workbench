resolve_mode_target() {
  local mode="$1"
  case "$mode" in
    light|dark)
      printf '%s\n' "$mode"
      ;;
    toggle)
      if [ "$(read_current_mode)" = "light" ]; then
        printf '%s\n' 'dark'
      else
        printf '%s\n' 'light'
      fi
      ;;
    *)
      echo "Unsupported mode: $mode (expected: light, dark, toggle)" >&2
      return 1
      ;;
  esac
}

apply_mode() {
  local requested_mode="$1"
  local resolved_mode scheme_name scheme_file

  resolved_mode="$(resolve_mode_target "$requested_mode")"
  scheme_name="$(read_mode_theme_name "$resolved_mode")"
  scheme_file="$(resolve_scheme_file "$scheme_name" || true)"
  if [ -z "$scheme_file" ]; then
    echo "Scheme not found for $resolved_mode mode: $scheme_name" >&2
    echo "Run: weztheme --list" >&2
    exit 1
  fi

  apply_scheme "$scheme_file"
  generate_vim_colorscheme "$scheme_file" "$scheme_name"
  generate_tmux_theme "$scheme_file" "$scheme_name"

  if [ "$PERSIST" -eq 1 ]; then
    persist_scheme "$scheme_file" "$scheme_name"
    persist_mode_theme "$resolved_mode" "$scheme_file" "$scheme_name"
    persist_mode_state "$resolved_mode"
    sync_hermes_skin "$resolved_mode"
    echo "Applied and persisted $resolved_mode mode: $scheme_name"
  else
    echo "Applied $resolved_mode mode (not persisted): $scheme_name"
  fi

  if [ -n "${TMUX:-}" ] && [ -f "$TMUX_THEME_FILE" ]; then
    tmux source-file "$TMUX_THEME_FILE" >/dev/null 2>&1 || true
  fi
}

SCHEME_NAME=""
MODE_NAME=""
SET_LIGHT_NAME=""
SET_DARK_NAME=""
PREVIEW_NAME=""
DESCRIBE_NAME=""
DO_LIST=0
DO_REFRESH=0
DO_CLEAR=0
DO_SHOW_MODE_THEMES=0
PERSIST=1

while [ $# -gt 0 ]; do
  case "$1" in
    --set)
      SCHEME_NAME="${2:-}"
      shift 2
      ;;
    --mode)
      MODE_NAME="${2:-}"
      shift 2
      ;;
    --set-light)
      SET_LIGHT_NAME="${2:-}"
      shift 2
      ;;
    --set-dark)
      SET_DARK_NAME="${2:-}"
      shift 2
      ;;
    --show-mode-themes)
      DO_SHOW_MODE_THEMES=1
      shift
      ;;
    --preview-theme)
      PREVIEW_NAME="${2:-}"
      shift 2
      ;;
    --describe-theme)
      DESCRIBE_NAME="${2:-}"
      shift 2
      ;;
    --list)
      DO_LIST=1
      shift
      ;;
    --refresh)
      DO_REFRESH=1
      shift
      ;;
    --clear)
      DO_CLEAR=1
      shift
      ;;
    --no-persist)
      PERSIST=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [ "$DO_CLEAR" -eq 1 ]; then
  clear_persisted
  exit 0
fi

if [ -n "$PREVIEW_NAME" ]; then
  preview_scheme_name "$PREVIEW_NAME"
  exit 0
fi

if [ -n "$DESCRIBE_NAME" ]; then
  describe_scheme_name "$DESCRIBE_NAME"
  exit 0
fi

if [ "$DO_REFRESH" -eq 1 ]; then
  refresh_repo
fi

if [ "$DO_SHOW_MODE_THEMES" -eq 1 ]; then
  ensure_repo
  show_mode_themes
  exit 0
fi

if [ -n "$SET_LIGHT_NAME" ]; then
  ensure_repo
  set_mode_theme_name light "$SET_LIGHT_NAME"
  exit 0
fi

if [ -n "$SET_DARK_NAME" ]; then
  ensure_repo
  set_mode_theme_name dark "$SET_DARK_NAME"
  exit 0
fi

if [ "$DO_LIST" -eq 1 ]; then
  list_schemes
  exit 0
fi

if [ -n "$MODE_NAME" ]; then
  ensure_repo
  if [ -z "${WEZTERM_PANE:-}" ] && [ "${TERM_PROGRAM:-}" != "WezTerm" ]; then
    echo "Warning: not running inside WezTerm; colors may not apply here." >&2
  fi
  apply_mode "$MODE_NAME"
  exit 0
fi

if [ -z "$SCHEME_NAME" ]; then
  SCHEME_NAME="$(pick_scheme_interactive || true)"
fi

if [ -z "$SCHEME_NAME" ]; then
  exit 0
fi

ensure_repo
SCHEME_FILE="$(resolve_scheme_file "$SCHEME_NAME" || true)"
if [ -z "$SCHEME_FILE" ]; then
  echo "Scheme not found: $SCHEME_NAME" >&2
  echo "Run: weztheme --list" >&2
  exit 1
fi

if [ -z "${WEZTERM_PANE:-}" ] && [ "${TERM_PROGRAM:-}" != "WezTerm" ]; then
  echo "Warning: not running inside WezTerm; colors may not apply here." >&2
fi

apply_scheme "$SCHEME_FILE"
generate_vim_colorscheme "$SCHEME_FILE" "$SCHEME_NAME"
generate_tmux_theme "$SCHEME_FILE" "$SCHEME_NAME"

if [ "$PERSIST" -eq 1 ]; then
  persist_scheme "$SCHEME_FILE" "$SCHEME_NAME"
  echo "Applied and persisted: $SCHEME_NAME"
else
  echo "Applied (not persisted): $SCHEME_NAME"
fi

if [ -n "${TMUX:-}" ] && [ -f "$TMUX_THEME_FILE" ]; then
  tmux source-file "$TMUX_THEME_FILE" >/dev/null 2>&1 || true
fi
