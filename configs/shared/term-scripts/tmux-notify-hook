#!/usr/bin/env bash
set -euo pipefail

event="${1:-unknown}"
hook_pane="${2:-}"
hook_window="${3:-}"

log_file="${XDG_CACHE_HOME:-$HOME/.cache}/terminal-notify.log"
mkdir -p "$(dirname "$log_file")"

tmux_fmt() {
  local target="$1"
  local format="$2"
  tmux display-message -p -t "$target" "$format" 2>/dev/null || true
}

target="${hook_pane:-$hook_window}"
session_name="unknown"
window_name="unknown"
window_active=""
pane_command=""
pane_dead_status=""
pane_label="${hook_pane:-?}"

if [[ -n "$target" ]]; then
  session_name="$(tmux_fmt "$target" '#{session_name}')"
  window_name="$(tmux_fmt "$target" '#{window_name}')"
  window_active="$(tmux_fmt "$target" '#{window_active}')"
  pane_command="$(tmux_fmt "$target" '#{pane_current_command}')"
  pane_dead_status="$(tmux_fmt "$target" '#{pane_dead_status}')"
fi
if [[ -z "$session_name" ]]; then session_name="unknown"; fi
if [[ -z "$window_name" ]]; then window_name="unknown"; fi
if [[ -n "$hook_pane" ]]; then pane_label="$hook_pane"; fi

printf '%s event=%q session=%q window=%q pane=%q active=%q cmd=%q status=%q\n' \
  "$(date '+%F %T')" "$event" "$session_name" "$window_name" "$pane_label" "$window_active" "$pane_command" "$pane_dead_status" >> "$log_file"

if [[ "$event" == "alert-bell" && "${TMUX_NOTIFY_BELL_ACTIVE:-0}" != "1" && "$window_active" == "1" ]]; then
  exit 0
fi

state_dir="${XDG_CACHE_HOME:-$HOME/.cache}/tmux-notify-state"
mkdir -p "$state_dir"
state_file="$state_dir/${event}-${session_name}-${window_name}-${pane_label}.ts"
now_epoch="$(date +%s)"
if [[ "$event" == "alert-bell" ]]; then
  last_epoch="0"
  if [[ -f "$state_file" ]]; then
    last_epoch="$(cat "$state_file" 2>/dev/null || printf '0')"
  fi
  if [[ $(( now_epoch - last_epoch )) -lt ${TMUX_NOTIFY_BELL_MIN_GAP_SECONDS:-5} ]]; then
    exit 0
  fi
  printf '%s' "$now_epoch" > "$state_file"
fi

short_cmd="${pane_command:-pane}"
case "$event" in
  alert-bell)
    title="tmux alert • ${session_name}:${window_name}"
    body="Bell from ${short_cmd} (${pane_label})"
    ;;
  pane-exited)
    title="tmux pane exited • ${session_name}:${window_name}"
    if [[ -n "$pane_dead_status" ]]; then
      body="${short_cmd} (${pane_label}) exited with status ${pane_dead_status}"
    else
      body="${short_cmd} (${pane_label}) exited"
    fi
    ;;
  *)
    title="tmux event • ${session_name}:${window_name}"
    body="${event} on ${short_cmd} (${pane_label})"
    ;;
esac

if command -v hermes-win-notify >/dev/null 2>&1; then
  hermes-win-notify "$title" "$body" >/dev/null 2>&1 || true
elif command -v terminal-notifier >/dev/null 2>&1; then
  terminal-notifier -title "$title" -message "$body" >/dev/null 2>&1 || true
elif command -v osascript >/dev/null 2>&1; then
  osascript - "$title" "$body" >/dev/null 2>&1 <<'APPLESCRIPT' || true
on run argv
  display notification (item 2 of argv) with title (item 1 of argv)
end run
APPLESCRIPT
elif command -v notify-send >/dev/null 2>&1; then
  notify-send "$title" "$body" >/dev/null 2>&1 || true
fi
