#!/usr/bin/env bash
set -euo pipefail

required=(tmux fzf rg yazi lazygit)
optional=(codex hermes opencode openclaw ghostty wezterm)

missing_required=()
missing_optional=()

for tool in "${required[@]}"; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    missing_required+=("$tool")
  fi
done

for tool in "${optional[@]}"; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    missing_optional+=("$tool")
  fi
done

echo "Agentic CLI Workbench doctor"
echo

if ((${#missing_required[@]} == 0)); then
  echo "OK required tools found: ${required[*]}"
else
  echo "Missing required tools: ${missing_required[*]}"
fi

if ((${#missing_optional[@]} == 0)); then
  echo "OK optional agent/terminal tools found: ${optional[*]}"
else
  echo "Optional tools not found: ${missing_optional[*]}"
fi

echo
echo "Next:"
echo "  ./scripts/demo-session prepare hermes"
echo "  ./scripts/demo-session show hermes"

if ((${#missing_required[@]} > 0)); then
  exit 1
fi
